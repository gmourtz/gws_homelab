{
  "agents": {
    "defaults": {
      "model": { "primary": "openai/gpt-5.4-mini" },
      "models": { "openai/gpt-5.4-mini": {} },
      "compaction": { "mode": "safeguard" }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "workspace": "~/.openclaw/workspace",
        "agentDir": "~/.openclaw/agents/main/agent"
      }{% if openclaw_health_mcp_enabled | default(false) %},
      {
        "id": "health-coach",
        "name": "Health Coach",
        "workspace": "~/.openclaw/workspace-health",
        "agentDir": "~/.openclaw/agents/health-coach/agent"
      }{% endif %}
    ]
  },
  "models": {
    "providers": {
      "openai": {
        "agentRuntime": { "id": "openclaw" }
      }
    }
  },
  "commands": { "native": "auto", "nativeSkills": "auto", "restart": true, "ownerDisplay": "raw" },
  "channels": {
    "telegram": {
      "enabled": true,
      "defaultAccount": "default",
      "accounts": {
        "default": {
          "botToken": "{{ vault_openclaw_telegram_token }}",
          "dmPolicy": "allowlist",
          "allowFrom": [{{ vault_telegram_chat_id }}],
          "groupPolicy": "allowlist"
        }{% if openclaw_health_mcp_enabled | default(false) %},
        "coach": {
          "name": "Health Coach",
          "botToken": "{{ vault_openclaw_health_telegram_token }}",
          "dmPolicy": "allowlist",
          "allowFrom": [{{ vault_telegram_chat_id }}],
          "groupPolicy": "allowlist"
        }{% endif %}
      },
      "streaming": {}
    }
  },
{% if openclaw_health_mcp_enabled | default(false) %}
  "bindings": [
    { "type": "route", "agentId": "health-coach", "match": { "channel": "telegram", "accountId": "coach" } }
  ],
{% endif %}
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "trustedProxies": ["172.18.0.0/16", "127.0.0.1"],
    "controlUi": {
      "allowedOrigins": [
        "https://{{ tailscale_fqdn }}",
        "http://{{ ansible_host }}:{{ tailscale_serve_port }}"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "{{ vault_openclaw_gateway_token }}",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": { "enabled": true },
      "codex": { "enabled": false }
    }
  }{% if openclaw_gcal_mcp_enabled | default(false) or openclaw_health_mcp_enabled | default(false) %},
  "mcp": {
    "servers": {
{%- if openclaw_gcal_mcp_enabled | default(false) %}
      "google-calendar": {
        "command": "npx",
        "args": ["-y", "@cocal/google-calendar-mcp@2.6.1"],
        "env": {
          "TRANSPORT": "stdio",
          "GOOGLE_OAUTH_CREDENTIALS": "/home/node/.openclaw/gcal/gcp-oauth.keys.json",
          "GOOGLE_CALENDAR_MCP_TOKEN_PATH": "/home/node/.openclaw/gcal/tokens.json",
          "NPM_CONFIG_CACHE": "/home/node/.openclaw/.npm"
        }
      }{% if openclaw_health_mcp_enabled | default(false) %},{% endif %}
{%- endif %}
{%- if openclaw_health_mcp_enabled | default(false) %}
      "health": {
        "url": "http://optiplex.internal:8100/mcp",
        "transport": "streamable-http"
      }
{%- endif %}
    }
  }{% endif %}
}
