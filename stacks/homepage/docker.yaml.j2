---
# optiplex — connect via docker-socket-proxy on the shared docker-proxy-net
optiplex:
  host: docker-socket-proxy
  port: 2375

# rpi3 / localllm — socket-proxy bound to each host's LAN IP (see their stacks), reached over the LAN
rpi3:
  host: 192.168.10.10
  port: 2375

localllm:
  host: 192.168.10.30
  port: 2375
