---
- Media:
    - Jellyfin:
        href: https://jellyfin.{{ local_domain }}/
        icon: jellyfin.png
        description: Media server
        server: optiplex
        container: jellyfin
        widget:
          type: jellyfin
          url: http://jellyfin:8096
          key: {{ vault_homepage_jellyfin_api_key }}
          version: 2
          enableBlocks: true
          enableNowPlaying: true
          fields: ["movies", "series", "songs"]

    - Audiobookshelf:
        href: https://audiobookshelf.{{ local_domain }}/
        icon: audiobookshelf.png
        description: Audiobooks & podcasts
        server: optiplex
        container: audiobookshelf
        widget:
          type: audiobookshelf
          url: http://audiobookshelf:80
          key: {{ vault_homepage_audiobookshelf_api_key }}
          fields: ["books", "podcasts", "podcastEpisodes"]

    - Immich:
        href: https://immich.{{ local_domain }}/
        icon: immich.png
        description: Photo management
        server: optiplex
        container: immich-server

    - Navidrome:
        href: https://navidrome.{{ local_domain }}/
        icon: navidrome.png
        description: Music streaming (Subsonic)
        server: optiplex
        container: navidrome

    - Jellyseerr:
        href: https://jellyseerr.{{ local_domain }}/
        icon: jellyseerr.png
        description: Media requests
        server: optiplex
        container: jellyseerr
        widget:
          type: jellyseerr
          url: http://jellyseerr:5055
          key: {{ vault_homepage_jellyseerr_api_key }}
          fields: ["pending", "approved", "available"]

    - MusicSeerr:
        href: https://musicseerr.{{ local_domain }}/
        icon: musicseerr.png
        description: Music requests
        server: optiplex
        container: musicseerr

- Monitoring:
    - optiplex:
        href: https://beszel.{{ local_domain }}/
        icon: beszel.png
        description: i5-6500T · 6GB RAM · 240GB SSD
        server: optiplex
        container: beszel-hub
        widget:
          type: beszel
          url: http://beszel-hub:8090
          username: {{ vault_homepage_beszel_username }}
          password: {{ vault_homepage_beszel_password }}
          systemId: {{ vault_homepage_beszel_id_optiplex }}
          version: 2
          fields: ["cpu", "memory", "disk", "network"]

    - rpi3:
        href: https://beszel.{{ local_domain }}/
        icon: beszel.png
        description: Raspberry Pi 3 B+ · 906MB RAM
        widget:
          type: beszel
          url: http://beszel-hub:8090
          username: {{ vault_homepage_beszel_username }}
          password: {{ vault_homepage_beszel_password }}
          systemId: {{ vault_homepage_beszel_id_rpi3 }}
          version: 2
          fields: ["cpu", "memory", "disk", "network"]

    # kali (RPi 5) is an isolated lab box on VLAN 50 with no Beszel agent.
    # Browse lab targets directly: juice-shop.internal:3000,
    # webgoat.internal:8080.

    - openclaw:
        href: https://beszel.{{ local_domain }}/
        icon: beszel.png
        description: Lenovo · i5-8265U · 8GB RAM
        widget:
          type: beszel
          url: http://beszel-hub:8090
          username: {{ vault_homepage_beszel_username }}
          password: {{ vault_homepage_beszel_password }}
          systemId: {{ vault_homepage_beszel_id_openclaw }}
          version: 2
          fields: ["cpu", "memory", "disk", "network"]

    - localllm:
        href: https://beszel.{{ local_domain }}/
        icon: beszel.png
        description: OptiPlex 7010 · i7-13700T · 16GB DDR5 · 256GB NVMe
        widget:
          type: beszel
          url: http://beszel-hub:8090
          username: {{ vault_homepage_beszel_username }}
          password: {{ vault_homepage_beszel_password }}
          systemId: {{ vault_homepage_beszel_id_localllm }}
          version: 2
          fields: ["cpu", "memory", "disk", "network"]

    - Uptime Kuma:
        href: https://uptime-kuma.{{ local_domain }}/
        icon: uptime-kuma.png
        description: Service uptime monitoring
        server: optiplex
        container: uptime-kuma

    - Pi-hole:
        href: http://pihole.{{ local_domain }}/admin/
        icon: pi-hole.png
        description: DNS & ad blocking
        server: rpi3
        container: pihole
        widget:
          type: pihole
          url: http://192.168.10.10
          version: 6
          key: {{ vault_pihole_password }}
          fields: ["queries", "blocked", "blocked_percent", "gravity"]

- Lab:
    # kali (RPi 5, VLAN 50) — deliberately-vulnerable targets, on-demand.
    # They live behind the `lab` Compose profile, so they're usually stopped;
    # start a session with: docker compose --profile lab up -d juice-shop webgoat
    - Juice Shop:
        href: http://kali.{{ local_domain }}:3000/
        icon: mdi-bottle-soda-classic
        description: OWASP Juice Shop — on-demand (kali)
    - WebGoat:
        href: http://kali.{{ local_domain }}:8080/WebGoat
        icon: mdi-shield-bug
        description: OWASP WebGoat / WebWolf — on-demand (kali)

- AI:
    - Open WebUI:
        href: https://chat.{{ local_domain }}/
        icon: open-webui.png
        description: Local LLM chat (Gemma 4)
        server: localllm
        container: open-webui

    - Ollama API:
        href: http://localllm.{{ local_domain }}:11434/
        icon: ollama.png
        description: Local LLM API endpoint
        server: localllm
        container: ollama
        widget:
          type: customapi
          url: http://localllm.{{ local_domain }}:11434/api/ps
          refreshInterval: 30000
          display: dynamic-list
          mappings:
            items: models
            name: name
            label: details.parameter_size

- Tools:
    - Paperless:
        href: https://paperless.{{ local_domain }}/
        icon: paperless-ngx.png
        description: Document management
        server: optiplex
        container: paperless-ngx
        widget:
          type: paperlessngx
          url: http://paperless-ngx:8000
          username: {{ vault_paperless_admin_user }}
          password: {{ vault_paperless_admin_password }}
          fields: ["total", "inbox"]

    - Stirling PDF:
        href: https://stirling-pdf.{{ local_domain }}/
        icon: stirling-pdf.png
        description: PDF tools
        server: optiplex
        container: stirling-pdf

    - IT Tools:
        href: https://it-tools.{{ local_domain }}/
        icon: it-tools.png
        description: Developer utilities
        server: optiplex
        container: it-tools

    - Draw.io:
        href: https://drawio.{{ local_domain }}/
        icon: drawio.png
        description: Diagrams
        server: optiplex
        container: drawio

    - Actual Budget:
        href: https://actual-budget.{{ local_domain }}/
        icon: actual-budget.png
        description: Personal finance
        server: optiplex
        container: actual-budget

    - Miniflux:
        href: https://miniflux.{{ local_domain }}/
        icon: miniflux.png
        description: RSS reader
        server: optiplex
        container: miniflux
        widget:
          type: miniflux
          url: http://miniflux:8080
          key: {{ vault_homepage_miniflux_api_key }}

- Downloads:
    - YouTube Videos:
        href: https://jellyfin.{{ local_domain }}/
        icon: youtube.png
        description: Video playlist sync
        server: optiplex
        container: youtube-video-downloader

    - YouTube Music:
        href: https://jellyfin.{{ local_domain }}/
        icon: youtube.png
        description: Music playlist sync (FLAC)
        server: optiplex
        container: youtube-music-downloader

    - qBittorrent:
        href: https://qbittorrent.{{ local_domain }}/
        icon: qbittorrent.png
        description: BitTorrent client (via Mullvad VPN)
        server: optiplex
        container: qbittorrent

    - Radarr:
        href: https://radarr.{{ local_domain }}/
        icon: radarr.png
        description: Movie acquisition
        server: optiplex
        container: radarr

    - Sonarr:
        href: https://sonarr.{{ local_domain }}/
        icon: sonarr.png
        description: TV show acquisition
        server: optiplex
        container: sonarr

    - Prowlarr:
        href: https://prowlarr.{{ local_domain }}/
        icon: prowlarr.png
        description: Indexer manager
        server: optiplex
        container: prowlarr

    - Lidarr:
        href: https://lidarr.{{ local_domain }}/
        icon: lidarr.png
        description: Music acquisition
        server: optiplex
        container: lidarr

    - Bazarr:
        href: https://bazarr.{{ local_domain }}/
        icon: bazarr.png
        description: Subtitle management
        server: optiplex
        container: bazarr

- Infrastructure:
    - Cloudflare Tunnel:
        href: https://dash.cloudflare.com/
        icon: cloudflare.png
        description: Public tunnel
        server: optiplex
        container: cloudflared
        widget:
          type: cloudflared
          accountid: {{ vault_homepage_cf_account_id }}
          tunnelid: {{ vault_homepage_cf_tunnel_id }}
          key: {{ vault_homepage_cf_token }}
          fields: ["status", "origin_ip"]

    - Dozzle:
        href: https://dozzle.{{ local_domain }}/
        icon: dozzle.png
        description: Container logs
        server: optiplex
        container: dozzle

    - Caddy:
        icon: caddy.png
        description: Reverse proxy (no admin UI)
        server: optiplex
        container: caddy

- Home:
    - Air Quality:
        href: https://air-quality.{{ local_domain }}/
        icon: mdi-air-filter
        description: Awair Element sensors (temp, humidity, CO2, VOC, PM2.5)
        server: optiplex
        container: air-quality-dashboard
