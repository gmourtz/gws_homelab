- Infrastructure:
    - Cloudflare Tunnel:
        href: https://dash.cloudflare.com/
        icon: cloudflare.png
        description: Public tunnel
        server: optiplex
        container: cloudflared
        widget:
          type: cloudflared
          accountid: {{ vault_homepage_cf_account_id }}
          tunnelid: {{ vault_homepage_cf_tunnel_id }}
          key: {{ vault_homepage_cf_token }}
          fields: ["status", "origin_ip"]

    - Dozzle:
        href: https://dozzle.{{ local_domain }}/
        icon: dozzle.png
        description: Container logs
        server: optiplex
        container: dozzle

    - Caddy:
        icon: caddy.png
        description: Reverse proxy (no admin UI)
        server: optiplex
        container: caddy
