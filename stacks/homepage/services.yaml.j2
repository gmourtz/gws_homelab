    - Uptime Kuma:
        href: https://uptime-kuma.{{ local_domain }}/
        icon: uptime-kuma.png
        description: Service uptime monitoring
        server: optiplex
        container: uptime-kuma

    - Pi-hole:
        href: http://pihole.{{ local_domain }}/admin/
        icon: pi-hole.png
        description: DNS & ad blocking
        server: rpi3
        container: pihole
        widget:
          type: pihole
          url: http://192.168.10.10
          version: 6
          key: {{ vault_homepage_pihole_api_key }}
          fields: ["queries", "blocked", "blocked_percent", "gravity"]

