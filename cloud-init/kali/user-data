#cloud-config
# Cloud-init user-data for Raspberry Pi 5 (Kali Linux 2026+)
# Placed on the BOOT partition of the SD card by flash.sh.
# Pattern mirrors cloud-init/rpi3/user-data — bare metal setup only.
# OS config (Docker, UFW, lab targets) is handled by bootstrap-kali.yml.

hostname: kali
manage_etc_hosts: true

locale: en_US.UTF-8
timezone: Europe/London

users:
  - default
  - name: gws
    groups: [sudo]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILjZb5ELR3VYw8eSNGTf9eAY8kqeA/LuRIhD8X/fzpup gws_homelab

ssh_pwauth: false

runcmd:
  - systemctl enable ssh --now
  - sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
  - sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config
  - systemctl restart ssh

power_state:
  mode: reboot
  message: "Cloud-init complete — rebooting"
  timeout: 30
